<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Laporan Pemeriksaan"
            android:textColor="#1E293B"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_result_patient_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Memuat profil..."
            android:textColor="#64748B"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/ll_status_background"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#DEF7EC"> <!-- Light Green default -->

                <TextView
                    android:id="@+id/tv_risk_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RISIKO RENDAH"
                    android:textColor="#03543F"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_combined_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kondisi kesehatan fisik anak terpantau normal. Pertumbuhan anak sejalan dengan indikator gizi dasar."
                    android:textColor="#046C4E"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Details Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rincian Parameter"
            android:textColor="#475569"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <!-- Eyes Scan Results -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Analisis Kelopak Mata (Anemia)"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_result_eyes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Memproses..."
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Nails Scan Results -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Analisis Kuku (Koilonychia / Malnutrisi)"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_result_nails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Memproses..."
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Questionnaire Score -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. Hasil Kuesioner Tumbuh Kembang"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_result_questionnaire"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Memproses..."
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Nutrition Recommendation -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F0FDF4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saran Nutrisi &amp; Tindakan Lokal"
                    android:textColor="#166534"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_nutrition_rec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Membuat saran..."
                    android:textColor="#14532D"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Maps Referral Button -->
        <Button
            android:id="@+id/btn_open_maps"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cari Rujukan Puskesmas Terdekat"
            android:textColor="#6366F1"
            app:strokeColor="#6366F1"
            android:layout_marginTop="16dp"
            android:padding="12dp" />

        <!-- PDF Export Button -->
        <Button
            android:id="@+id/btn_export_pdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ekspor &amp; Bagikan Laporan (PDF)"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6366F1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>
