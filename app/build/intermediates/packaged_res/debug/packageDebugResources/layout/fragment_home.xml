<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_dashboard_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard Screening"
        android:textColor="#1E293B"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_dashboard_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pemantauan Kesehatan &amp; Tumbuh Kembang Offline"
        android:textColor="#64748B"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_dashboard_title"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Bypass Indicator Badge -->
    <TextView
        android:id="@+id/tv_bypass_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bypass Active (Mock AI)"
        android:background="#FEF3C7"
        android:textColor="#D97706"
        android:textSize="12sp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Info Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_info_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#EFF6FF"
        app:layout_constraintTop_toBottomOf="@id/tv_dashboard_subtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aplikasi Offline Mandiri"
                android:textColor="#1E40AF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seluruh proses komputasi AI dan basis data berjalan secara lokal di perangkat Anda tanpa memakan kuota internet."
                android:textColor="#1E3A8A"
                android:textSize="13sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_patients_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profil Anak Terdaftar"
        android:textColor="#334155"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cv_info_card"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Belum ada profil anak terdaftar. Tekan tombol di bawah untuk membuat profil pertama."
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tv_patients_header" />

    <!-- RecyclerView for patients -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_patients"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/tv_patients_header"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Bottom Float Action Buttons -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_add_patient"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Profil Anak"
        app:icon="@android:drawable/ic_input_add"
        android:textColor="#FFFFFF"
        app:iconTint="#FFFFFF"
        android:backgroundTint="#6366F1"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
