<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top instructions header -->
    <LinearLayout
        android:id="@+id/ll_scanner_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#99000000"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_scanner_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Langkah 1/3: Pemindaian Mata"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_scanner_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Posisikan kelopak mata bagian bawah (konjungtiva) anak di dalam area kotak pemandu."
            android:textColor="#CBD5E1"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Overlay visual guide box -->
    <View
        android:id="@+id/view_guide_box"
        android:layout_width="260dp"
        android:layout_height="200dp"
        android:background="@drawable/scanner_guide_box"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom controller bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#99000000"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_capture"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/btn_capture_circle"
            android:contentDescription="Ambil Foto" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
